module

public import BConicBundleMultisections.BiprojectiveDehomogenization
public import BConicBundleMultisections.BiprojectiveOverlapScheme
public import BConicBundleMultisections.BiprojectiveSpaceProperties
public import BConicBundleMultisections.IdealSheafDescent

/-!
# Biprojective zero loci

This file constructs the local principal ideal sheaves associated to a Cox-coordinate
polynomial on the standard charts of `ProjectiveSpace m R ×[Spec R] ProjectiveSpace n R`.
For a bihomogeneous polynomial, these local ideals are descended to a global ideal sheaf;
its associated closed subscheme is the canonical biprojective zero locus.

The chart rings are concrete tensor products, whereas an ideal sheaf is expressed using global
sections of the corresponding affine chart schemes.  `BiprojectiveSpace.standardChartΓIso`
is the canonical comparison used to transport each chart equation between these presentations.
-/

@[expose] public section

open CategoryTheory Limits
open scoped AlgebraicGeometry

namespace BConicBundleMultisections

noncomputable section

universe u

open AlgebraicGeometry

namespace BiprojectiveSpace

/-- Global functions on a standard product chart identify with its tensor-product chart ring. -/
def standardChartΓIso (m n : ℕ) (R : Type u) [CommRing R]
    (i : Fin (m + 1)) (j : Fin (n + 1)) :
    Γ(standardChart m n R i j, ⊤) ≅ .of (StandardChartRing m n R i j) :=
  (asIso (Scheme.Γ.map (standardChartIsoSpec m n R i j).hom.op)).symm ≪≫
    Scheme.ΓSpecIso (.of (StandardChartRing m n R i j))

/-- The chart equation, regarded as a global function on the corresponding chart scheme. -/
def chartEquationSection (m n : ℕ) (R : Type u) [CommRing R]
    (i : Fin (m + 1)) (j : Fin (n + 1))
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    Γ(standardChart m n R i j, ⊤) :=
  (standardChartΓIso m n R i j).inv (chartEquation m n R i j F)

@[simp]
theorem standardChartΓIso_hom_chartEquationSection (m n : ℕ)
    (R : Type u) [CommRing R] (i : Fin (m + 1)) (j : Fin (n + 1))
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    (standardChartΓIso m n R i j).hom (chartEquationSection m n R i j F) =
      chartEquation m n R i j F := by
  simp [chartEquationSection]

/-- The principal ideal generated by the chart equation in the chart's global functions. -/
def chartIdealTop (m n : ℕ) (R : Type u) [CommRing R]
    (i : Fin (m + 1)) (j : Fin (n + 1))
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    Ideal Γ(standardChart m n R i j, ⊤) :=
  Ideal.span {chartEquationSection m n R i j F}

@[simp]
theorem chartEquationSection_mem_chartIdealTop (m n : ℕ)
    (R : Type u) [CommRing R] (i : Fin (m + 1)) (j : Fin (n + 1))
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    chartEquationSection m n R i j F ∈ chartIdealTop m n R i j F :=
  Ideal.subset_span (Set.mem_singleton _)

/-- The principal ideal sheaf cut out by `F` on one standard product chart. -/
def chartIdealSheaf (m n : ℕ) (R : Type u) [CommRing R]
    (i : Fin (m + 1)) (j : Fin (n + 1))
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    (standardChart m n R i j).IdealSheafData :=
  Scheme.IdealSheafData.ofIdealTop (chartIdealTop m n R i j F)

@[simp]
theorem chartIdealSheaf_ideal_top (m n : ℕ) (R : Type u) [CommRing R]
    (i : Fin (m + 1)) (j : Fin (n + 1))
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    (chartIdealSheaf m n R i j F).ideal ⟨⊤, isAffineOpen_top _⟩ =
      chartIdealTop m n R i j F := by
  simp [chartIdealSheaf]

private lemma ideal_comap_ofIdealTop_eq_map_appTop
    {X Y : Scheme.{u}} [IsAffine X] [IsAffine Y]
    (I : Ideal Γ(Y, ⊤)) (f : X ⟶ Y) [IsOpenImmersion f] :
    ((Scheme.IdealSheafData.ofIdealTop I).comap f).ideal
        ⟨⊤, isAffineOpen_top X⟩ = Ideal.map f.appTop.hom I := by
  rw [Scheme.IdealSheafData.ideal_comap_of_isOpenImmersion]
  rw [Scheme.IdealSheafData.ofIdealTop_ideal]
  let U : Y.Opens := f ''ᵁ (⊤ : X.Opens)
  let e : Γ(Y, U) ≃+* Γ(X, ⊤) :=
    (f.appIso (⊤ : X.Opens)).commRingCatIsoToRingEquiv
  let J : Ideal Γ(Y, U) :=
    Ideal.map (Y.presheaf.map (homOfLE (le_top : U ≤ ⊤)).op).hom I
  change Ideal.comap e.symm.toRingHom J = _
  calc
    _ = Ideal.map e.toRingHom J := by
      exact (Ideal.map_comap_of_equiv (I := J) e).symm
    _ = Ideal.map f.appTop.hom I := by
      dsimp only [J]
      rw [Ideal.map_map]
      congr 1
      change
        (Y.presheaf.map (homOfLE (le_top : U ≤ ⊤)).op ≫
          (f.appIso (⊤ : X.Opens)).hom).hom = f.appTop.hom
      congr 1
      rw [Scheme.Hom.appIso_hom']
      rw [f.map_appLE
          (V := (⊤ : X.Opens)) (U := U) (U' := ⊤)
          ((f.preimage_image_eq (⊤ : X.Opens)).ge)
          (homOfLE (le_top : U ≤ ⊤)).op]
      unfold Scheme.Hom.appLE
      change f.appTop ≫ _ = f.appTop
      rw [← Category.comp_id f.appTop]
      congr 1
      rw [← X.presheaf.map_id]
      exact congrArg X.presheaf.map (Subsingleton.elim _ _)

/-- The global-sections map from the first chart to an explicit overlap is conjugate to the
concrete localization map between their coordinate rings. -/
@[reassoc]
lemma overlapToChart_appTop_standardChartΓIso
    (m n : ℕ) (R : Type u) [CommRing R]
    (i i' : Fin (m + 1)) (j j' : Fin (n + 1)) :
    (overlapToChart m n R i i' j j').appTop ≫
        (Scheme.ΓSpecIso (.of (OverlapRing m n R i i' j j'))).hom =
      (standardChartΓIso m n R i j).hom ≫
        CommRingCat.ofHom (chartToOverlap m n R i i' j j').toRingHom := by
  unfold overlapToChart standardChartΓIso
  rw [Scheme.Hom.comp_appTop]
  simp only [Scheme.Γ_map_op]
  rw [Category.assoc, Scheme.ΓSpecIso_naturality]
  have hinv : (standardChartIsoSpec m n R i j).inv =
      inv (standardChartIsoSpec m n R i j).hom := by
    rw [← asIso_inv]
    exact (Iso.inv_eq_inv _ _).2 rfl
  rw [hinv, Scheme.Hom.inv_appTop]
  rfl

/-- The global-sections map from the second chart to an explicit overlap is conjugate to the
concrete localization map between their coordinate rings. -/
@[reassoc]
lemma overlapToOtherChart_appTop_standardChartΓIso
    (m n : ℕ) (R : Type u) [CommRing R]
    (i i' : Fin (m + 1)) (j j' : Fin (n + 1)) :
    (overlapToOtherChart m n R i i' j j').appTop ≫
        (Scheme.ΓSpecIso (.of (OverlapRing m n R i i' j j'))).hom =
      (standardChartΓIso m n R i' j').hom ≫
        CommRingCat.ofHom (otherChartToOverlap m n R i i' j j').toRingHom := by
  unfold overlapToOtherChart standardChartΓIso
  rw [Scheme.Hom.comp_appTop]
  simp only [Scheme.Γ_map_op]
  rw [Category.assoc, Scheme.ΓSpecIso_naturality]
  have hinv : (standardChartIsoSpec m n R i' j').inv =
      inv (standardChartIsoSpec m n R i' j').hom := by
    rw [← asIso_inv]
    exact (Iso.inv_eq_inv _ _).2 rfl
  rw [hinv, Scheme.Hom.inv_appTop]
  rfl

private lemma map_standardChartΓIso_chartIdealTop
    (m n : ℕ) (R : Type u) [CommRing R]
    (i : Fin (m + 1)) (j : Fin (n + 1))
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    Ideal.map (standardChartΓIso m n R i j).hom.hom
        (chartIdealTop m n R i j F) =
      Ideal.span {chartEquation m n R i j F} := by
  unfold chartIdealTop
  rw [Ideal.map_span, Set.image_singleton]
  rw [standardChartΓIso_hom_chartEquationSection]

/-- The principal ideal sheaves defined on two standard charts have equal restrictions to their
scheme-theoretic intersection. -/
theorem chartIdealSheaf_comap_overlap_eq
    (m n : ℕ) (R : Type u) [CommRing R]
    (i i' : Fin (m + 1)) (j j' : Fin (n + 1))
    {d e : ℕ} (F : MvPolynomial (BiprojectiveCoordinate m n) R)
    (hF : IsBihomogeneousOfBidegree d e F) :
    (chartIdealSheaf m n R i j F).comap (overlapToChart m n R i i' j j') =
      (chartIdealSheaf m n R i' j' F).comap
        (overlapToOtherChart m n R i i' j j') := by
  let h := overlap_isPullback m n R i i' j j'
  letI : IsOpenImmersion (overlapToChart m n R i i' j j') := by
    exact IsOpenImmersion.of_isPullback h.flip inferInstance
  letI : IsOpenImmersion (overlapToOtherChart m n R i i' j j') := by
    exact IsOpenImmersion.of_isPullback h inferInstance
  apply Scheme.IdealSheafData.ext_of_isAffine
  unfold chartIdealSheaf
  rw [ideal_comap_ofIdealTop_eq_map_appTop]
  rw [ideal_comap_ofIdealTop_eq_map_appTop]
  let E : Γ(overlapScheme m n R i i' j j', ⊤) ≃+*
      OverlapRing m n R i i' j j' :=
    (Scheme.ΓSpecIso (.of (OverlapRing m n R i i' j j'))).commRingCatIsoToRingEquiv
  have hleft :
      E.toRingHom.comp (overlapToChart m n R i i' j j').appTop.hom =
        (chartToOverlap m n R i i' j j').toRingHom.comp
          (standardChartΓIso m n R i j).hom.hom := by
    exact congrArg CommRingCat.Hom.hom
      (overlapToChart_appTop_standardChartΓIso m n R i i' j j')
  have hright :
      E.toRingHom.comp (overlapToOtherChart m n R i i' j j').appTop.hom =
        (otherChartToOverlap m n R i i' j j').toRingHom.comp
          (standardChartΓIso m n R i' j').hom.hom := by
    exact congrArg CommRingCat.Hom.hom
      (overlapToOtherChart_appTop_standardChartΓIso m n R i i' j j')
  have hmapped :
      Ideal.map E.toRingHom
          (Ideal.map (overlapToChart m n R i i' j j').appTop.hom
            (chartIdealTop m n R i j F)) =
        Ideal.map E.toRingHom
          (Ideal.map (overlapToOtherChart m n R i i' j j').appTop.hom
            (chartIdealTop m n R i' j' F)) := by
    rw [Ideal.map_map, Ideal.map_map, hleft, hright]
    rw [← Ideal.map_map, ← Ideal.map_map]
    rw [map_standardChartΓIso_chartIdealTop, map_standardChartΓIso_chartIdealTop]
    exact map_span_chartEquation_overlap m n R i i' j j' F hF
  have hback := congrArg (Ideal.map E.symm.toRingHom) hmapped
  have hcancel (K : Ideal Γ(overlapScheme m n R i i' j j', ⊤)) :
      Ideal.map E.symm.toRingHom (Ideal.map E.toRingHom K) = K := by
    exact Ideal.map_of_equiv E
  rw [hcancel, hcancel] at hback
  exact hback

/-- The ideal sheaf obtained by extending the local chart equations to the ambient
biprojective space and taking their finite infimum.

This constructor is proof-independent: it does not require bihomogeneity of `F`.  Descent of
the local ideals to the expected chart ideals, and hence the local-to-global comparison with
the geometric zero locus of a bihomogeneous equation, is proved separately under that
hypothesis. -/
def biprojectiveZeroLocusIdeal (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    (BiprojectiveSpace m n R).IdealSheafData :=
  ⨅ ij : Fin (m + 1) × Fin (n + 1),
    (chartIdealSheaf m n R ij.1 ij.2 F).map
      (standardChartι m n R ij.1 ij.2)

/-- The closed subscheme of biprojective space cut out by the chart equations of `F`. -/
abbrev biprojectiveZeroLocus (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) : Scheme :=
  (biprojectiveZeroLocusIdeal m n R F).subscheme

/-- The canonical closed immersion of a biprojective zero locus into its ambient space. -/
abbrev biprojectiveZeroLocusι (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    biprojectiveZeroLocus m n R F ⟶ BiprojectiveSpace m n R :=
  (biprojectiveZeroLocusIdeal m n R F).subschemeι

/-- The structure morphism from a biprojective zero locus to the base affine scheme. -/
def biprojectiveZeroLocusToSpec (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    biprojectiveZeroLocus m n R F ⟶ Spec (.of R) :=
  biprojectiveZeroLocusι m n R F ≫ toSpec m n R

instance (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    (biprojectiveZeroLocus m n R F).CanonicallyOver (Spec (.of R)) where
  hom := biprojectiveZeroLocusToSpec m n R F

@[reassoc]
theorem biprojectiveZeroLocusι_toSpec
    (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    biprojectiveZeroLocusι m n R F ≫ toSpec m n R =
      biprojectiveZeroLocusToSpec m n R F :=
  rfl

/-- The restriction of the first ambient projection to a biprojective zero locus. -/
def biprojectiveZeroLocusFst (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    biprojectiveZeroLocus m n R F ⟶ ProjectiveSpace m R :=
  biprojectiveZeroLocusι m n R F ≫ fst m n R

/-- The restriction of the second ambient projection to a biprojective zero locus. -/
def biprojectiveZeroLocusSnd (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    biprojectiveZeroLocus m n R F ⟶ ProjectiveSpace n R :=
  biprojectiveZeroLocusι m n R F ≫ snd m n R

@[reassoc]
theorem biprojectiveZeroLocusFst_toSpec
    (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    biprojectiveZeroLocusFst m n R F ≫ ProjectiveSpace.toSpec m R =
      biprojectiveZeroLocusToSpec m n R F := by
  rw [biprojectiveZeroLocusFst, Category.assoc, fst_toSpec]
  rfl

@[reassoc]
theorem biprojectiveZeroLocusSnd_toSpec
    (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    biprojectiveZeroLocusSnd m n R F ≫ ProjectiveSpace.toSpec n R =
      biprojectiveZeroLocusToSpec m n R F := by
  rw [biprojectiveZeroLocusSnd, Category.assoc, snd_toSpec]
  rfl

/-- The first projection of a biprojective zero locus is proper. -/
instance (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    IsProper (biprojectiveZeroLocusFst m n R F) := by
  unfold biprojectiveZeroLocusFst
  infer_instance

/-- The second projection of a biprojective zero locus is proper. -/
instance (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    IsProper (biprojectiveZeroLocusSnd m n R F) := by
  unfold biprojectiveZeroLocusSnd
  infer_instance

/-- A biprojective zero locus is proper over its affine base scheme. -/
instance (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    IsProper (biprojectiveZeroLocusToSpec m n R F) := by
  unfold biprojectiveZeroLocusToSpec
  infer_instance

theorem ker_biprojectiveZeroLocusι
    (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    (biprojectiveZeroLocusι m n R F).ker =
      biprojectiveZeroLocusIdeal m n R F :=
  Scheme.IdealSheafData.ker_subschemeι _

/-- A chosen closed immersion presents a scheme as the zero locus of `F` when its kernel is the
canonical ideal sheaf obtained from the standard chart equations. This is deliberately a
structure, rather than a typeclass: the equation cannot be inferred from an arbitrary embedding. -/
structure IsBiprojectiveZeroLocus (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) {X : Scheme}
    (ι : X ⟶ BiprojectiveSpace m n R) : Prop where
  /-- The chosen presentation is a closed immersion into the ambient space. -/
  isClosedImmersion : IsClosedImmersion ι
  /-- The presentation has the canonical ideal sheaf defined by the chart equations. -/
  ker_eq : ι.ker = biprojectiveZeroLocusIdeal m n R F

/-- The canonical immersion presents the canonical subscheme as the zero locus. -/
theorem isBiprojectiveZeroLocus_biprojectiveZeroLocusι
    (m n : ℕ) (R : Type u) [CommRing R]
    (F : MvPolynomial (BiprojectiveCoordinate m n) R) :
    IsBiprojectiveZeroLocus m n R F
      (biprojectiveZeroLocusι m n R F) where
  isClosedImmersion := inferInstance
  ker_eq := Scheme.IdealSheafData.ker_subschemeι _

namespace IsBiprojectiveZeroLocus

/-- A presentation of the zero locus is canonically isomorphic to the subscheme constructed from
the chart equations. -/
noncomputable def isoBiprojectiveZeroLocus
    {m n : ℕ} {R : Type u} [CommRing R]
    {F : MvPolynomial (BiprojectiveCoordinate m n) R}
    {X : Scheme} {ι : X ⟶ BiprojectiveSpace m n R}
    (hι : IsBiprojectiveZeroLocus m n R F ι) :
    X ≅ biprojectiveZeroLocus m n R F := by
  letI : IsClosedImmersion ι := hι.isClosedImmersion
  have hker : (biprojectiveZeroLocusι m n R F).ker = ι.ker := by
    rw [ker_biprojectiveZeroLocusι, hι.ker_eq]
  let f := IsClosedImmersion.lift
    (biprojectiveZeroLocusι m n R F) ι hker.le
  letI : IsIso f := IsClosedImmersion.isIso_lift
    (biprojectiveZeroLocusι m n R F) ι hker
  exact asIso f

@[reassoc]
theorem isoBiprojectiveZeroLocus_hom_comp
    {m n : ℕ} {R : Type u} [CommRing R]
    {F : MvPolynomial (BiprojectiveCoordinate m n) R}
    {X : Scheme} {ι : X ⟶ BiprojectiveSpace m n R}
    (hι : IsBiprojectiveZeroLocus m n R F ι) :
    (isoBiprojectiveZeroLocus (m := m) (n := n) (R := R)
      (F := F) (X := X) (ι := ι) hι).hom ≫
        biprojectiveZeroLocusι m n R F = ι := by
  letI : IsClosedImmersion ι := hι.isClosedImmersion
  change IsClosedImmersion.lift
    (biprojectiveZeroLocusι m n R F) ι _ ≫
      biprojectiveZeroLocusι m n R F = ι
  exact IsClosedImmersion.lift_fac _ _ _

/-- The canonical isomorphism from a chosen presentation also respects the structure morphisms
to the affine base. -/
@[reassoc]
theorem isoBiprojectiveZeroLocus_hom_comp_toSpec
    {m n : ℕ} {R : Type u} [CommRing R]
    {F : MvPolynomial (BiprojectiveCoordinate m n) R}
    {X : Scheme} {ι : X ⟶ BiprojectiveSpace m n R}
    (hι : IsBiprojectiveZeroLocus m n R F ι) :
    (isoBiprojectiveZeroLocus (m := m) (n := n) (R := R)
      (F := F) (X := X) (ι := ι) hι).hom ≫
        biprojectiveZeroLocusToSpec m n R F =
      ι ≫ toSpec m n R := by
  unfold biprojectiveZeroLocusToSpec
  rw [← Category.assoc, isoBiprojectiveZeroLocus_hom_comp hι]

end IsBiprojectiveZeroLocus

/-- The ideal on one standard chart is contained in the restriction of the
scheme-theoretic closure of the ideal on any other standard chart. -/
theorem chartIdealSheaf_le_comap_map
    (m n : ℕ) (R : Type u) [CommRing R]
    (i i' : Fin (m + 1)) (j j' : Fin (n + 1))
    {d e : ℕ} (F : MvPolynomial (BiprojectiveCoordinate m n) R)
    (hF : IsBihomogeneousOfBidegree d e F) :
    chartIdealSheaf m n R i' j' F ≤
      ((chartIdealSheaf m n R i j F).map
        (standardChartι m n R i j)).comap
          (standardChartι m n R i' j') := by
  apply Scheme.IdealSheafData.le_comap_map_of_isPullback
    (overlapToChart m n R i i' j j')
    (overlapToOtherChart m n R i i' j j')
    (standardChartι m n R i j)
    (standardChartι m n R i' j')
    (overlap_isPullback m n R i i' j j')
  exact chartIdealSheaf_comap_overlap_eq m n R i i' j j' F hF

/-- The global ideal of a bihomogeneous polynomial restricts to its prescribed principal ideal
on every standard chart. -/
theorem biprojectiveZeroLocusIdeal_comap_standardChartι
    (m n : ℕ) (R : Type u) [CommRing R]
    {d e : ℕ} (F : MvPolynomial (BiprojectiveCoordinate m n) R)
    (hF : IsBihomogeneousOfBidegree d e F)
    (i : Fin (m + 1)) (j : Fin (n + 1)) :
    (biprojectiveZeroLocusIdeal m n R F).comap
        (standardChartι m n R i j) =
      chartIdealSheaf m n R i j F := by
  apply Scheme.IdealSheafData.finiteOpenClosure_comap_eq
    (fun ij : Fin (m + 1) × Fin (n + 1) =>
      standardChart m n R ij.1 ij.2)
    (fun ij => standardChartι m n R ij.1 ij.2)
    (fun ij => chartIdealSheaf m n R ij.1 ij.2 F)
    (i, j)
  intro ij ij'
  exact chartIdealSheaf_le_comap_map m n R ij.1 ij'.1 ij.2 ij'.2 F hF

/-- The local zero locus on a standard chart is the pullback of the global zero locus. -/
noncomputable def chartZeroLocusIsoPullback
    (m n : ℕ) (R : Type u) [CommRing R]
    {d e : ℕ} (F : MvPolynomial (BiprojectiveCoordinate m n) R)
    (hF : IsBihomogeneousOfBidegree d e F)
    (i : Fin (m + 1)) (j : Fin (n + 1)) :
    (chartIdealSheaf m n R i j F).subscheme ≅
      pullback (standardChartι m n R i j)
        (biprojectiveZeroLocusι m n R F) := by
  let ι := pullback.fst (standardChartι m n R i j)
    (biprojectiveZeroLocusι m n R F)
  let ι' := (chartIdealSheaf m n R i j F).subschemeι
  have hker : ι.ker = ι'.ker := by
    rw [Scheme.IdealSheafData.ker_fst_of_isClosedImmersion,
      ker_biprojectiveZeroLocusι,
      biprojectiveZeroLocusIdeal_comap_standardChartι m n R F hF,
      Scheme.IdealSheafData.ker_subschemeι]
  let f := IsClosedImmersion.lift ι ι' hker.le
  letI : IsIso f := IsClosedImmersion.isIso_lift ι ι' hker
  exact asIso f

@[reassoc]
theorem chartZeroLocusIsoPullback_hom_fst
    (m n : ℕ) (R : Type u) [CommRing R]
    {d e : ℕ} (F : MvPolynomial (BiprojectiveCoordinate m n) R)
    (hF : IsBihomogeneousOfBidegree d e F)
    (i : Fin (m + 1)) (j : Fin (n + 1)) :
    (chartZeroLocusIsoPullback m n R F hF i j).hom ≫
        pullback.fst _ _ =
      (chartIdealSheaf m n R i j F).subschemeι := by
  change IsClosedImmersion.lift _ _ _ ≫ _ = _
  exact IsClosedImmersion.lift_fac _ _ _

/-- Ideal sheaves on the ambient biprojective space are determined by their restrictions to the
standard affine cover. -/
theorem idealSheafData_eq_of_comap_standardChartι_eq
    (m n : ℕ) (R : Type u) [CommRing R]
    {I J : (BiprojectiveSpace m n R).IdealSheafData}
    (H : ∀ i : Fin (m + 1), ∀ j : Fin (n + 1),
      I.comap (standardChartι m n R i j) =
        J.comap (standardChartι m n R i j)) :
    I = J := by
  apply Scheme.IdealSheafData.ext_of_iSup_eq_top
    (fun ij : Fin (m + 1) × Fin (n + 1) =>
      standardChartAffineOpen m n R ij.1 ij.2)
    (iSup_standardChartAffineOpen m n R)
  rintro ⟨i, j⟩
  let f := standardChartι m n R i j
  let U : (standardChart m n R i j).affineOpens :=
    ⟨⊤, isAffineOpen_top _⟩
  have h := congrArg (fun K => K.ideal U) (H i j)
  rw [Scheme.IdealSheafData.ideal_comap_of_isOpenImmersion,
    Scheme.IdealSheafData.ideal_comap_of_isOpenImmersion] at h
  have h' := Ideal.comap_injective_of_surjective
    (f.appIso U).inv.hom
    (ConcreteCategory.bijective_of_isIso (f.appIso U).inv).2 h
  let V : (BiprojectiveSpace m n R).affineOpens :=
    ⟨f ''ᵁ U, U.2.image_of_isOpenImmersion f⟩
  have hV : standardChartAffineOpen m n R i j = V := by
    apply Subtype.ext
    exact (Scheme.Hom.image_top_eq_opensRange f).symm
  rw [hV]
  exact h'

/-- The finite-infimum construction is the unique ambient ideal sheaf whose restriction to each
standard chart is the prescribed bihomogeneous chart ideal. -/
theorem eq_biprojectiveZeroLocusIdeal_of_comap_standardChartι_eq
    (m n : ℕ) (R : Type u) [CommRing R]
    {d e : ℕ} (F : MvPolynomial (BiprojectiveCoordinate m n) R)
    (hF : IsBihomogeneousOfBidegree d e F)
    (I : (BiprojectiveSpace m n R).IdealSheafData)
    (hI : ∀ i : Fin (m + 1), ∀ j : Fin (n + 1),
      I.comap (standardChartι m n R i j) =
        chartIdealSheaf m n R i j F) :
    I = biprojectiveZeroLocusIdeal m n R F := by
  apply idealSheafData_eq_of_comap_standardChartι_eq m n R
  intro i j
  rw [biprojectiveZeroLocusIdeal_comap_standardChartι m n R F hF]
  exact hI i j

end BiprojectiveSpace

