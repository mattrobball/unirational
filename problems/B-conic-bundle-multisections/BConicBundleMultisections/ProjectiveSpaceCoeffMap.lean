module

public import BConicBundleMultisections.ProjectiveSpace
public import Mathlib.AlgebraicGeometry.ProjectiveSpectrum.Functor
public import Mathlib.RingTheory.GradedAlgebra.Homogeneous.Maps
public import Mathlib.RingTheory.GradedAlgebra.RingHom

/-!
# Coefficient-extension morphisms of projective space

A ring homomorphism `φ : R →+* S` induces a graded ring homomorphism on homogeneous coordinate
rings of projective space, and therefore a scheme morphism
`ProjectiveSpace n S → ProjectiveSpace n R` via Mathlib's `Proj.map`.

The irrelevant-ideal hypothesis `ℬ₊ ≤ 𝒜₊.map f` holds because the irrelevant ideal is generated by
the variables `Xᵢ`, each of which is the image of the corresponding variable over `R`.
-/

@[expose] public section

open CategoryTheory
open scoped AlgebraicGeometry HomogeneousIdeal

namespace BConicBundleMultisections

noncomputable section

universe u

open AlgebraicGeometry HomogeneousIdeal MvPolynomial ProjectiveSpace

attribute [local instance] MvPolynomial.gradedAlgebra

/-- Graded ring homomorphism induced by coefficient extension on homogeneous coordinate rings. -/
def coeffGradedRingHom {R S : Type u} [CommRing R] [CommRing S] (φ : R →+* S) (n : ℕ) :
    (homogeneousSubmodule (Fin (n + 1)) R) →+*ᵍ
      (homogeneousSubmodule (Fin (n + 1)) S) where
  toRingHom := map φ
  map_mem {_i} {_a} ha := ha.map φ

theorem X_mem_irrelevant (n : ℕ) (T : Type u) [CommRing T] (i : Fin (n + 1)) :
    (X i : MvPolynomial (Fin (n + 1)) T) ∈
      ((homogeneousSubmodule (Fin (n + 1)) T)₊).toIdeal :=
  mem_irrelevant_of_mem (𝒜 := homogeneousSubmodule (Fin (n + 1)) T)
    (by decide : (0 : ℕ) < 1) (isHomogeneous_X T i)

/-- Coefficient extension preserves the irrelevant ideal in the sense required by `Proj.map`. -/
theorem irrelevant_le_map_coeff {R S : Type u} [CommRing R] [CommRing S]
    (φ : R →+* S) (n : ℕ) :
    (homogeneousSubmodule (Fin (n + 1)) S)₊ ≤
      ((homogeneousSubmodule (Fin (n + 1)) R)₊).map (coeffGradedRingHom φ n) := by
  rw [← toIdeal_le_toIdeal_iff]
  intro x hx
  have hxspan : x ∈ Ideal.span (Set.range (X : Fin (n + 1) → MvPolynomial (Fin (n + 1)) S)) :=
    ProjectiveSpace.irrelevant_le_span_X n S hx
  have hgen :
      Ideal.span (Set.range (X : Fin (n + 1) → MvPolynomial (Fin (n + 1)) S)) ≤
        Ideal.map (coeffGradedRingHom φ n).toRingHom
          ((homogeneousSubmodule (Fin (n + 1)) R)₊).toIdeal := by
    apply Ideal.span_le.mpr
    rintro z ⟨i, rfl⟩
    have hX : (X i : MvPolynomial (Fin (n + 1)) S) =
        (coeffGradedRingHom φ n).toRingHom (X i : MvPolynomial (Fin (n + 1)) R) := by
      simp [coeffGradedRingHom, map_X]
    rw [hX]
    exact Ideal.mem_map_of_mem _ (X_mem_irrelevant n R i)
  change x ∈ Ideal.map (coeffGradedRingHom φ n).toRingHom
    ((homogeneousSubmodule (Fin (n + 1)) R)₊).toIdeal
  exact hgen hxspan

/-- Scheme morphism `ℙⁿ_S → ℙⁿ_R` induced by a coefficient ring homomorphism `R → S`. -/
def mapCoeff {R S : Type u} [CommRing R] [CommRing S] (φ : R →+* S) (n : ℕ) :
    ProjectiveSpace n S ⟶ ProjectiveSpace n R :=
  Proj.map (coeffGradedRingHom φ n) (irrelevant_le_map_coeff φ n)

end

end BConicBundleMultisections
