public import Mathlib.RingTheory.Ideal.IsPrincipalPowQuotient

/-!
# Jacobian consequences of smooth biprojective affine charts

For a nonzero polynomial `f` over a field, the conormal module of the hypersurface quotient
`K[X] ⧸ (f)` is free of rank one, generated by the class of `f`. Formal smoothness therefore
forces the classes of the partial derivatives of `f` to generate the unit ideal in the quotient.

The final results apply this to the explicit affine equations of a biprojective zero locus. In
particular, if the global zero locus is smooth and a chart equation is nonzero, that chart equation
and all of its partial derivatives have no common zero.
-/

@[expose] public section

open CategoryTheory
open scoped AlgebraicGeometry

namespace BConicBundleMultisections

noncomputable section

universe u v

namespace Hypersurface

variable {K : Type u} [Field K] {σ : Type v}

/-- The polynomial extension presenting the hypersurface quotient `K[X] ⧸ (f)`. -/
noncomputable abbrev extension (f : MvPolynomial σ K) :
    Algebra.Extension K (MvPolynomial σ K ⧸ Ideal.span {f}) where
  Ring := MvPolynomial σ K
  algebra₂ := Ideal.Quotient.algebra (MvPolynomial σ K)
  isScalarTower := Ideal.Quotient.isScalarTower K (MvPolynomial σ K) (Ideal.span {f})
  σ x := (Ideal.Quotient.mk_surjective x).choose
  algebraMap_σ x := (Ideal.Quotient.mk_surjective x).choose_spec

@[simp]
theorem extension_ker (f : MvPolynomial σ K) :
    (extension f).ker = Ideal.span {f} := by
  ext x
  change Ideal.Quotient.mk (Ideal.span {f}) x = 0 ↔ x ∈ Ideal.span {f}
  exact Ideal.Quotient.eq_zero_iff_mem

/-- Multiplication by `f`, regarded as a map into the kernel of the quotient presentation. -/
noncomputable def kernelMul (f : MvPolynomial σ K) :
    MvPolynomial σ K →ₗ[MvPolynomial σ K] (extension f).ker where
  toFun a := ⟨a * f, (extension_ker f).symm ▸
    Ideal.mul_mem_left _ _ (Ideal.mem_span_singleton_self f)⟩
  map_add' a b := by
    apply Subtype.ext
    exact add_mul a b f
  map_smul' r a := by
    apply Subtype.ext
    exact mul_assoc r a f

/-- The class of a multiple of `f` in the conormal module. -/
noncomputable def cotangentRaw (f : MvPolynomial σ K) :
    MvPolynomial σ K →ₗ[MvPolynomial σ K] (extension f).Cotangent :=
  (Algebra.Extension.Cotangent.mk (P := extension f)).comp (kernelMul f)

/-- The quotient-linear generator map before its scalar ring is restricted to the quotient. -/
noncomputable def cotangentGeneratorMapRing (f : MvPolynomial σ K) :
    (MvPolynomial σ K ⧸ Ideal.span {f}) →ₗ[MvPolynomial σ K]
      (extension f).Cotangent :=
  (Ideal.span {f}).liftQ (cotangentRaw f) <| by
    intro a ha
    rw [LinearMap.mem_ker]
    change Algebra.Extension.Cotangent.mk ((kernelMul f) a) = 0
    rw [Algebra.Extension.Cotangent.mk_eq_zero_iff]
    change a * f ∈ (extension f).ker ^ 2
    simpa only [extension_ker, pow_two] using
      Ideal.mul_mem_mul ha (Ideal.mem_span_singleton_self f)

@[simp]
theorem cotangentGeneratorMapRing_mk (f a : MvPolynomial σ K) :
    cotangentGeneratorMapRing f (Ideal.Quotient.mk (Ideal.span {f}) a) =
      Algebra.Extension.Cotangent.mk
        ⟨a * f, (extension_ker f).symm ▸
          Ideal.mul_mem_left _ _ (Ideal.mem_span_singleton_self f)⟩ := by
  change ((Ideal.span {f}).liftQ (cotangentRaw f) _)
    (Submodule.Quotient.mk a) = _
  rw [Submodule.liftQ_apply]
  rfl

theorem cotangentGeneratorMapRing_injective
    (f : MvPolynomial σ K) (hf : f ≠ 0) :
    Function.Injective (cotangentGeneratorMapRing f) := by
  rw [← LinearMap.ker_eq_bot]
  ext x
  simp only [LinearMap.mem_ker, Submodule.mem_bot]
  constructor
  · intro hx
    obtain ⟨a, rfl⟩ := Ideal.Quotient.mk_surjective x
    rw [cotangentGeneratorMapRing_mk,
      Algebra.Extension.Cotangent.mk_eq_zero_iff] at hx
    change a * f ∈ (extension f).ker ^ 2 at hx
    rw [extension_ker, pow_two] at hx
    rw [Ideal.Quotient.eq_zero_iff_mem]
    rw [Ideal.span_singleton_mul_span_singleton,
      Ideal.mem_span_singleton'] at hx
    rw [Ideal.mem_span_singleton']
    obtain ⟨b, hb⟩ := hx
    exact ⟨b, (mul_right_inj' hf).mp (by
      simpa only [mul_assoc, mul_comm, mul_left_comm] using hb)⟩
  · rintro rfl
    exact LinearMap.map_zero _

theorem cotangentGeneratorMapRing_surjective (f : MvPolynomial σ K) :
    Function.Surjective (cotangentGeneratorMapRing f) := by
  intro y
  obtain ⟨⟨g, hg⟩, rfl⟩ := Algebra.Extension.Cotangent.mk_surjective y
  have hg' : g ∈ Ideal.span {f} := by
    simpa only [extension_ker] using hg
  obtain ⟨a, ha⟩ := Ideal.mem_span_singleton'.mp hg'
  refine ⟨Ideal.Quotient.mk (Ideal.span {f}) a, ?_⟩
  rw [cotangentGeneratorMapRing_mk]
  congr 1
  exact Subtype.ext ha

theorem cotangentGeneratorMapRing_bijective
    (f : MvPolynomial σ K) (hf : f ≠ 0) :
    Function.Bijective (cotangentGeneratorMapRing f) :=
  ⟨cotangentGeneratorMapRing_injective f hf,
    cotangentGeneratorMapRing_surjective f⟩

/-- The generator equivalence, first regarded as linear over the polynomial ring. -/
noncomputable def cotangentGeneratorEquivRing
    (f : MvPolynomial σ K) (hf : f ≠ 0) :
    (MvPolynomial σ K ⧸ Ideal.span {f}) ≃ₗ[MvPolynomial σ K]
      (extension f).Cotangent :=
  LinearEquiv.ofBijective (cotangentGeneratorMapRing f)
    (cotangentGeneratorMapRing_bijective f hf)

/-- For a nonzero principal hypersurface, `I / I²` is a free rank-one module over the
quotient, with generator the class of the defining equation. -/
noncomputable def principalConormalEquiv
    (f : MvPolynomial σ K) (hf : f ≠ 0) :
    (MvPolynomial σ K ⧸ Ideal.span {f})
      ≃ₗ[MvPolynomial σ K ⧸ Ideal.span {f}] (extension f).Cotangent where
  toFun := cotangentGeneratorEquivRing f hf
  invFun := (cotangentGeneratorEquivRing f hf).symm
  left_inv := (cotangentGeneratorEquivRing f hf).left_inv
  right_inv := (cotangentGeneratorEquivRing f hf).right_inv
  map_add' := (cotangentGeneratorEquivRing f hf).map_add
  map_smul' s x := by
    obtain ⟨s, rfl⟩ := Ideal.Quotient.mk_surjective s
    exact (cotangentGeneratorEquivRing f hf).map_smul s x

@[simp]
theorem principalConormalEquiv_mk
    (f : MvPolynomial σ K) (hf : f ≠ 0) (a : MvPolynomial σ K) :
    principalConormalEquiv f hf (Ideal.Quotient.mk (Ideal.span {f}) a) =
      Algebra.Extension.Cotangent.mk
        ⟨a * f, (extension_ker f).symm ▸
          Ideal.mul_mem_left _ _ (Ideal.mem_span_singleton_self f)⟩ :=
  cotangentGeneratorMapRing_mk f a

/-- The standard quotient-module structure on the cotangent space, supplied explicitly to keep
typeclass search shallow. -/
@[reducible]
noncomputable def cotangentSpaceModule (f : MvPolynomial σ K) :
    Module (MvPolynomial σ K ⧸ Ideal.span {f}) (extension f).CotangentSpace := by
  letI : IsScalarTower (extension f).Ring
      (MvPolynomial σ K ⧸ Ideal.span {f})
      (MvPolynomial σ K ⧸ Ideal.span {f}) := IsScalarTower.right
  letI : IsScalarTower
      (MvPolynomial σ K ⧸ Ideal.span {f})
      (MvPolynomial σ K ⧸ Ideal.span {f})
      (MvPolynomial σ K ⧸ Ideal.span {f}) := IsScalarTower.right
  let hcomm : SMulCommClass (extension f).Ring
      (MvPolynomial σ K ⧸ Ideal.span {f})
      (MvPolynomial σ K ⧸ Ideal.span {f}) :=
    SMulCommClass.of_commMonoid _ _ _
  exact @TensorProduct.leftModule _ _ _ _ _ _ _ _ _ _ _ hcomm

attribute [local instance] cotangentSpaceModule

/-- The coordinate differential basis of the hypersurface presentation's cotangent space. -/
noncomputable def cotangentSpaceBasis (f : MvPolynomial σ K) :
    @Module.Basis σ (MvPolynomial σ K ⧸ Ideal.span {f})
      (extension f).CotangentSpace _ _ (cotangentSpaceModule f) :=
  (KaehlerDifferential.mvPolynomialBasis K σ).baseChange
    (MvPolynomial σ K ⧸ Ideal.span {f})

@[simp]
theorem cotangentSpaceBasis_repr_D
    (f : MvPolynomial σ K) (i : σ) :
    (cotangentSpaceBasis f).repr
        (1 ⊗ₜ[MvPolynomial σ K]
          KaehlerDifferential.D K (MvPolynomial σ K) f) i =
      Ideal.Quotient.mk (Ideal.span {f}) (MvPolynomial.pderiv i f) := by
  change ((KaehlerDifferential.mvPolynomialBasis K σ).baseChange
      (MvPolynomial σ K ⧸ Ideal.span {f})).repr
        (1 ⊗ₜ[MvPolynomial σ K]
          KaehlerDifferential.D K (MvPolynomial σ K) f) i = _
  rw [Module.Basis.baseChange_repr_tmul,
    KaehlerDifferential.mvPolynomialBasis_repr_apply]
  change Ideal.Quotient.mk (Ideal.span {f}) (MvPolynomial.pderiv i f) * 1 = _
  rw [mul_one]

/-- If the quotient by a nonzero hypersurface equation is smooth, the classes of its partial
derivatives generate the unit ideal in the quotient. -/
theorem pderiv_span_eq_top_of_smooth
    [Finite σ] (f : MvPolynomial σ K) (hf : f ≠ 0)
    (hsmooth : RingHom.Smooth
      (algebraMap K (MvPolynomial σ K ⧸ Ideal.span {f}))) :
    Ideal.span (Set.range fun i : σ =>
      Ideal.Quotient.mk (Ideal.span {f}) (MvPolynomial.pderiv i f)) = ⊤ := by
  classical
  letI := Fintype.ofFinite σ
  letI : Algebra.Smooth K (MvPolynomial σ K ⧸ Ideal.span {f}) :=
    RingHom.smooth_algebraMap.mp hsmooth
  letI : Algebra.FormallySmooth K (MvPolynomial σ K ⧸ Ideal.span {f}) :=
    Algebra.Smooth.formallySmooth
  obtain ⟨l, hl⟩ := (extension f).formallySmooth_iff_split_injection.mp inferInstance
  let e := principalConormalEquiv f hf
  let q := e.symm.toLinearMap.comp l
  let u : (extension f).CotangentSpace :=
    1 ⊗ₜ[MvPolynomial σ K]
      KaehlerDifferential.D K (MvPolynomial σ K) f
  have he : (extension f).cotangentComplex (e 1) = u := by
    change (extension f).cotangentComplex
      (e (Ideal.Quotient.mk (Ideal.span {f}) 1)) = u
    rw [principalConormalEquiv_mk, Algebra.Extension.cotangentComplex_mk]
    simp only [one_mul, u]
  have hsplit : l ((extension f).cotangentComplex (e 1)) = e 1 := by
    simpa only [LinearMap.comp_apply, LinearMap.id_apply] using
      LinearMap.congr_fun hl (e 1)
  have hq : q u = 1 := by
    change e.symm (l u) = 1
    rw [← he, hsplit, LinearEquiv.symm_apply_apply]
  let b := cotangentSpaceBasis f
  let c : σ → (MvPolynomial σ K ⧸ Ideal.span {f}) := fun i => q (b i)
  apply (Ideal.eq_top_iff_one _).mpr
  rw [Ideal.mem_span_range_iff_exists_fun]
  refine ⟨c, ?_⟩
  calc
    ∑ i, c i * Ideal.Quotient.mk (Ideal.span {f}) (MvPolynomial.pderiv i f) =
        ∑ i, Ideal.Quotient.mk (Ideal.span {f}) (MvPolynomial.pderiv i f) * c i := by
      apply Finset.sum_congr rfl
      intro i _
      rw [mul_comm]
    _ = ∑ i, q (Ideal.Quotient.mk (Ideal.span {f})
        (MvPolynomial.pderiv i f) • b i) := by
      apply Finset.sum_congr rfl
      intro i _
      rw [map_smul, smul_eq_mul]
    _ = q (∑ i, Ideal.Quotient.mk (Ideal.span {f})
        (MvPolynomial.pderiv i f) • b i) := by
      rw [map_sum]
    _ = q u := by
      congr 1
      rw [← b.sum_repr u]
      apply Finset.sum_congr rfl
      intro i _
      rw [cotangentSpaceBasis_repr_D]
    _ = 1 := hq

/-- At every zero of a nonzero smooth hypersurface equation, at least one partial derivative is
nonzero. -/
theorem exists_pderiv_ne_zero_at_of_smooth
    [Finite σ] (f : MvPolynomial σ K) (hf : f ≠ 0)
    (hsmooth : RingHom.Smooth
      (algebraMap K (MvPolynomial σ K ⧸ Ideal.span {f})))
    (a : σ → K) (ha : MvPolynomial.aeval a f = 0) :
    ∃ i : σ, MvPolynomial.aeval a (MvPolynomial.pderiv i f) ≠ 0 := by
  classical
  letI := Fintype.ofFinite σ
  by_contra h
  push Not at h
  have ha' : MvPolynomial.eval a f = 0 := by simpa using ha
  have h' : ∀ i : σ, MvPolynomial.eval a (MvPolynomial.pderiv i f) = 0 := by
    intro i
    simpa using h i
  have hspan := pderiv_span_eq_top_of_smooth f hf hsmooth
  have hI : ∀ p : MvPolynomial σ K, p ∈ Ideal.span {f} →
      MvPolynomial.aeval a p = 0 := by
    intro p hp
    obtain ⟨c, rfl⟩ := Ideal.mem_span_singleton'.mp hp
    rw [map_mul, ha, mul_zero]
  let ev : (MvPolynomial σ K ⧸ Ideal.span {f}) →ₐ[K] K :=
    Ideal.Quotient.liftₐ (Ideal.span {f}) (MvPolynomial.aeval a) hI
  have hone : (1 : MvPolynomial σ K ⧸ Ideal.span {f}) ∈
      Ideal.span (Set.range fun i : σ =>
        Ideal.Quotient.mk (Ideal.span {f}) (MvPolynomial.pderiv i f)) :=
    (Ideal.eq_top_iff_one _).mp hspan
  rw [Ideal.mem_span_range_iff_exists_fun] at hone
  obtain ⟨c, hc⟩ := hone
  have hc' := congrArg ev hc
  simp [ev, h'] at hc'

end Hypersurface

open AlgebraicGeometry

namespace BiprojectiveSpace

/-- Smoothness of the global biprojective zero locus makes the explicit coordinate-ring map of
every affine chart smooth. -/
theorem affineChartQuotient_smooth_of_global
    (m n : ℕ) (K : Type u) [Field K]
    {d e : ℕ} (F : MvPolynomial (BiprojectiveCoordinate m n) K)
    (hF : IsBihomogeneousOfBidegree d e F)
    (i : Fin (m + 1)) (j : Fin (n + 1))
    [Smooth (biprojectiveZeroLocusToSpec m n K F)] :
    RingHom.Smooth
      (algebraMap K
        (MvPolynomial (Fin m ⊕ Fin n) K ⧸
          Ideal.span {affineChartEquation m n K i j F})) := by
  let φ := CommRingCat.ofHom
    (algebraMap K
      (MvPolynomial (Fin m ⊕ Fin n) K ⧸
        Ideal.span {affineChartEquation m n K i j F}))
  change RingHom.Smooth φ.hom
  apply (HasRingHomProperty.Spec_iff (P := @Smooth) (φ := φ)).mp
  change Smooth (affineChartQuotientToSpec m n K i j F)
  rw [← MorphismProperty.cancel_left_of_respectsIso @Smooth
    (chartZeroLocusIsoSpecAffineQuotient m n K i j F).hom]
  rw [chartZeroLocusIsoSpecAffineQuotient_hom_toSpec m n K F hF i j]
  infer_instance

/-- On a nonzero affine chart equation of a globally smooth biprojective zero locus, every zero
has a nonvanishing partial derivative. -/
theorem exists_affineChartEquation_pderiv_ne_zero_at_of_global_smooth
    (m n : ℕ) (K : Type u) [Field K]
    {d e : ℕ} (F : MvPolynomial (BiprojectiveCoordinate m n) K)
    (hF : IsBihomogeneousOfBidegree d e F)
    (i : Fin (m + 1)) (j : Fin (n + 1))
    (hne : affineChartEquation m n K i j F ≠ 0)
    [Smooth (biprojectiveZeroLocusToSpec m n K F)]
    (a : (Fin m ⊕ Fin n) → K)
    (ha : MvPolynomial.aeval a (affineChartEquation m n K i j F) = 0) :
    ∃ k : Fin m ⊕ Fin n,
      MvPolynomial.aeval a
        (MvPolynomial.pderiv k (affineChartEquation m n K i j F)) ≠ 0 := by
  exact Hypersurface.exists_pderiv_ne_zero_at_of_smooth
    (affineChartEquation m n K i j F) hne
    (affineChartQuotient_smooth_of_global m n K F hF i j) a ha

/-- A nonzero affine chart equation of a globally smooth biprojective zero locus and all of its
partial derivatives have no common zero. -/
theorem no_common_zero_affineChartEquation_and_pderiv_of_global_smooth
    (m n : ℕ) (K : Type u) [Field K]
    {d e : ℕ} (F : MvPolynomial (BiprojectiveCoordinate m n) K)
    (hF : IsBihomogeneousOfBidegree d e F)
    (i : Fin (m + 1)) (j : Fin (n + 1))
    (hne : affineChartEquation m n K i j F ≠ 0)
    [Smooth (biprojectiveZeroLocusToSpec m n K F)]
    (a : (Fin m ⊕ Fin n) → K) :
    ¬ (MvPolynomial.aeval a (affineChartEquation m n K i j F) = 0 ∧
      ∀ k : Fin m ⊕ Fin n,
        MvPolynomial.aeval a
          (MvPolynomial.pderiv k (affineChartEquation m n K i j F)) = 0) := by
  rintro ⟨ha, hpartial⟩
  obtain ⟨k, hk⟩ := exists_affineChartEquation_pderiv_ne_zero_at_of_global_smooth
    m n K F hF i j hne a ha
  exact hk (hpartial k)

end BiprojectiveSpace

end

