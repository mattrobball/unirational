module

public import BConicBundleMultisections.BiprojectiveZeroLocus
public import BConicBundleMultisections.MultisectionPrinciple
public import BConicBundleMultisections.ResidualDivisor
public import Mathlib.AlgebraicGeometry.Morphisms.ClosedImmersion

/-!
# Residual image multisection of the conic projection

Given a biprojective equation `F`, form the residual divisor equation `q_F` of
`ResidualDivisor.residualEquation` (intended bidegree `(10,1)` for bidegree-`(2,3)` equations).
The residual image is the closed subscheme of biprojective space cut out by the ideal sheaf
generated by both `F` and `q_F`.  It sits inside the zero locus of `F` by the universal property of
closed immersions, and the second projection of that immersion is a multisection of the conic
fibration.

This module constructs the multisection data and records the polynomial-level residual-image
predicate.  Horizontality, birationality to a good vertical section, and the degree bound
`2a ≤ 20` are separate packages (good line, Lattès residual map, Picard/class computation).
-/

@[expose] public section

open CategoryTheory Limits
open scoped AlgebraicGeometry

namespace BConicBundleMultisections

noncomputable section

universe u

open AlgebraicGeometry BiprojectiveSpace ResidualDivisor

variable {k : Type u} [CommRing k]

/-! ### Ideal sheaf and closed subscheme of the residual image -/

/-- Ideal sheaf of the residual image: common zeros of `F` and its residual divisor equation. -/
def residualImageIdeal (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    (BiprojectiveSpace 2 2 k).IdealSheafData :=
  biprojectiveZeroLocusIdeal 2 2 k F ⊔
    biprojectiveZeroLocusIdeal 2 2 k (residualEquation F)

/-- Closed subscheme of biprojective space cut out by `F` and the residual divisor equation. -/
abbrev residualImage (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) : Scheme :=
  (residualImageIdeal F).subscheme

/-- Canonical closed immersion of the residual image into ambient biprojective space. -/
abbrev residualImageι (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    residualImage F ⟶ BiprojectiveSpace 2 2 k :=
  (residualImageIdeal F).subschemeι

theorem ker_residualImageι (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    (residualImageι F).ker = residualImageIdeal F :=
  Scheme.IdealSheafData.ker_subschemeι _

/-- The residual image ideal contains the hypersurface ideal of `F`. -/
theorem biprojectiveZeroLocusIdeal_le_residualImageIdeal
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    biprojectiveZeroLocusIdeal 2 2 k F ≤ residualImageIdeal F :=
  le_sup_left

/-- The residual image ideal contains the residual divisor ideal. -/
theorem residualDivisorIdeal_le_residualImageIdeal
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    biprojectiveZeroLocusIdeal 2 2 k (residualEquation F) ≤ residualImageIdeal F :=
  le_sup_right

/-! ### Multisection structure over the conic projection -/

/-- Closed immersion of the residual image into the zero locus of `F`. -/
def residualImageToZeroLocus (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    residualImage F ⟶ biprojectiveZeroLocus 2 2 k F :=
  IsClosedImmersion.lift
    (biprojectiveZeroLocusι 2 2 k F)
    (residualImageι F)
    (by
      rw [ker_biprojectiveZeroLocusι, ker_residualImageι]
      exact biprojectiveZeroLocusIdeal_le_residualImageIdeal F)

@[reassoc (attr := simp)]
theorem residualImageToZeroLocus_comp_ι
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    residualImageToZeroLocus F ≫ biprojectiveZeroLocusι 2 2 k F =
      residualImageι F :=
  IsClosedImmersion.lift_fac _ _ _

/-- Structure map of the residual image to the conic-fibration base `ℙ²`. -/
def residualImageToBase (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    residualImage F ⟶ ProjectiveSpace 2 k :=
  residualImageι F ≫ snd 2 2 k

/-- The residual image immersion is quasi-compact (closed immersion). -/
instance residualImageι_quasiCompact
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    QuasiCompact (residualImageι F) :=
  inferInstance

/-- The residual-image structure map to `ℙ²_y` is quasi-compact
(`closed immersion ≫ proper projection`). -/
instance residualImageToBase_quasiCompact
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    QuasiCompact (residualImageToBase F) := by
  dsimp [residualImageToBase]
  infer_instance

/-- The residual image, viewed as a multisection of the second (conic) projection of `{F = 0}`.

This is the regular multisection data extracted from the residual divisor equation on the
coordinate line `Y₂ = 0`.  Dominance / horizontality and rationality of a normalization are not
proved here.
-/
def residualMultisection (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    Multisection (biprojectiveZeroLocusSnd 2 2 k F) where
  carrier := residualImage F
  toBase := residualImageToBase F
  toTotal := residualImageToZeroLocus F
  toTotal_comp := by
    -- `toTotal ≫ π = residualImageι ≫ snd = toBase`
    dsimp [residualImageToBase, biprojectiveZeroLocusSnd]
    rw [← Category.assoc, residualImageToZeroLocus_comp_ι]

/-- Residual multisection base map is quasi-compact. -/
instance residualMultisection_toBase_quasiCompact
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    QuasiCompact (residualMultisection F).toBase :=
  residualImageToBase_quasiCompact F

/-- If the residual multisection base map is (topologically) dominant and the base is reduced,
it is scheme-theoretically horizontal. -/
theorem residualMultisection_isSchemeTheoreticallyHorizontal_of_isDominant
    [IsReduced (ProjectiveSpace 2 k)]
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k)
    [IsDominant (residualMultisection F).toBase] :
    (residualMultisection F).IsSchemeTheoreticallyHorizontal where
  isSchemeTheoreticallyDominant_toBase :=
    IsSchemeTheoreticallyDominant.of_isDominant _
  quasiCompact_toBase := inferInstance

@[simp]
theorem residualMultisection_carrier
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    (residualMultisection F).carrier = residualImage F :=
  rfl

@[simp]
theorem residualMultisection_toBase
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    (residualMultisection F).toBase = residualImageToBase F :=
  rfl

@[simp]
theorem residualMultisection_toTotal
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    (residualMultisection F).toTotal = residualImageToZeroLocus F :=
  rfl

/-- The multisection total map is a closed immersion into the ambient biprojective space after
composing with the hypersurface immersion. -/
theorem residualMultisection_toTotal_comp_ι
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    (residualMultisection F).toTotal ≫ biprojectiveZeroLocusι 2 2 k F =
      residualImageι F :=
  residualImageToZeroLocus_comp_ι F

/-- The multisection base map factors the ambient second projection through the residual image. -/
theorem residualMultisection_toBase_eq
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    (residualMultisection F).toBase =
      (residualMultisection F).toTotal ≫ biprojectiveZeroLocusSnd 2 2 k F :=
  (residualMultisection F).toTotal_comp.symm

/-! ### Base morphisms of the residual image -/

/-- Structure morphism of the residual image to the affine base. -/
def residualImageToSpec (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    residualImage F ⟶ Spec (.of k) :=
  residualImageι F ≫ toSpec 2 2 k

@[reassoc]
theorem residualImageToZeroLocus_comp_toSpec
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    residualImageToZeroLocus F ≫ biprojectiveZeroLocusToSpec 2 2 k F =
      residualImageToSpec F := by
  unfold residualImageToSpec biprojectiveZeroLocusToSpec
  rw [← Category.assoc, residualImageToZeroLocus_comp_ι]

/-- Base change of the residual multisection projects to the original zero locus. -/
theorem residualMultisection_baseChangeFst
    (F : MvPolynomial (BiprojectiveCoordinate 2 2) k) :
    (residualMultisection F).baseChangeFst =
      pullback.fst (biprojectiveZeroLocusSnd 2 2 k F) (residualImageToBase F) :=
  rfl

end

end BConicBundleMultisections
